@{
    ViewData["Title"] = "Home";
}

<div class="text-center py-5">
    <i class="bi bi-cup-hot-fill" style="font-size: 4rem; color: var(--brew-brown);"></i>
    <h1 class="mt-3 fw-bold" style="color: var(--brew-brown);">Welcome to BrewPoint</h1>
    <p class="lead text-muted">Your favourite coffee, ordered online in seconds.</p>
    <a href="/Coffee" class="btn btn-brew btn-lg mt-3">
        <i class="bi bi-list-ul"></i> Browse Our Menu
    </a>
</div>

<div class="row mt-5 g-4 text-center">
    <div class="col-md-4">
        <div class="card p-4 h-100">
            <i class="bi bi-search fs-1" style="color: var(--brew-accent);"></i>
            <h5 class="mt-3">Browse Menu</h5>
            <p class="text-muted">Explore our full range of coffees with custom ingredients.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card p-4 h-100">
            <i class="bi bi-cart-plus fs-1" style="color: var(--brew-accent);"></i>
            <h5 class="mt-3">Place an Order</h5>
            <p class="text-muted">Customise your order with sugar and extra ingredients.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card p-4 h-100">
            <i class="bi bi-clock-history fs-1" style="color: var(--brew-accent);"></i>
            <h5 class="mt-3">Track Orders</h5>
            <p class="text-muted">View your order history and current status in real time.</p>
        </div>
    </div>
</div>