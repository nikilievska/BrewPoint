@{
    ViewData["Title"] = "Admin Dashboard";
}

<h2 class="fw-bold mb-4" style="color: var(--brew-brown);">
    <i class="bi bi-speedometer2"></i> Admin Dashboard
</h2>

<div id="loadingMsg" class="text-center text-muted">Loading orders...</div>
<div id="errorMsg" class="alert alert-danger d-none"></div>
<div id="successMsg" class="alert alert-success d-none"></div>
<div id="ordersTable"></div>

@section Scripts {
    <script>
        async function loadAllOrders() {
            const token = localStorage.getItem('token');
            if (!token || localStorage.getItem('role') !== 'Admin') {
                window.location.href = '/';
                return;
            }

            try {
                const response = await fetch('/api/Admin/orders', {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                if (!response.ok) throw new Error();
                const orders = await response.json();
                document.getElementById('loadingMsg').style.display = 'none';
                renderTable(orders);
            } catch {
                document.getElementById('loadingMsg').style.display = 'none';
                document.getElementById('errorMsg').textContent = 'Failed to load orders.';
                document.getElementById('errorMsg').classList.remove('d-none');
            }
        }

        function statusBadge(status) {
            const map = {
                0: ['Pending', 'warning'],
                1: ['Preparing', 'info'],
                2: ['Ready', 'primary'],
                3: ['Completed', 'success'],
                4: ['Cancelled', 'danger']
            };
            const [label, color] = map[status] || ['Unknown', 'secondary'];
            return `<span class="badge bg-${color}">${label}</span>`;
        }

        function renderTable(orders) {
            if (orders.length === 0) {
                document.getElementById('ordersTable').innerHTML = '<p class="text-muted">No orders yet.</p>';
                return;
            }

            document.getElementById('ordersTable').innerHTML = `
                <div class="table-responsive">
                    <table class="table table-hover bg-white rounded shadow-sm">
                        <thead style="background-color: var(--brew-brown); color: white;">
                            <tr>
                                <th>#</th>
                                <th>Customer</th>
                                <th>Items</th>
                                <th>Total</th>
                                <th>Date</th>
                                <th>Status</th>
                                <th>Update</th>
                            </tr>
                        </thead>
                        <tbody>
                            ${orders.map(o => `
                                <tr>
                                    <td>${o.id}</td>
                                    <td>${o.userFullName || o.userId}</td>
                                    <td>
                                        ${o.items.map(i => `
                                            <div>
                                                <span class="fw-bold">${i.coffeeName}</span> x${i.quantity}
                                                ${i.sugarType ? `<small class="text-muted"> · ${i.sugarType}, ${i.sugarQuantity} spoon(s)</small>` : ''}
                                                ${i.extras?.length ? `<br><small class="text-muted">Extras: ${i.extras.map(e => `${e.ingredientName} (+$${e.priceAtOrder.toFixed(2)})`).join(', ')}</small>` : ''}
                                            </div>
                                        `).join('')}
                                    </td>
                                    <td class="fw-bold">$${o.totalPrice.toFixed(2)}</td>
                                    <td>${new Date(o.createdAt).toLocaleDateString()}</td>
                                    <td>${statusBadge(o.status)}</td>
                                    <td>
                                        <select class="form-select form-select-sm"
                                                onchange="updateStatus(${o.id}, this.value)"
                                                style="min-width: 120px;">
                                            <option value="0" ${o.status===0?'selected':''}>Pending</option>
                                            <option value="1" ${o.status===1?'selected':''}>Preparing</option>
                                            <option value="2" ${o.status===2?'selected':''}>Ready</option>
                                            <option value="3" ${o.status===3?'selected':''}>Completed</option>
                                            <option value="4" ${o.status===4?'selected':''}>Cancelled</option>
                                        </select>
                                    </td>
                                </tr>
                            `).join('')}
                        </tbody>
                    </table>
                </div>
            `;
        }

        async function updateStatus(orderId, newStatus) {
            const token = localStorage.getItem('token');
            const successMsg = document.getElementById('successMsg');
            const errorMsg = document.getElementById('errorMsg');

            try {
                const response = await fetch(`/api/Admin/orders/${orderId}/status`, {
                    method: 'PATCH',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${token}`
                    },
                    body: JSON.stringify({ status: parseInt(newStatus) })
                });

                if (!response.ok) throw new Error();

                successMsg.textContent = `Order #${orderId} status updated.`;
                successMsg.classList.remove('d-none');
                setTimeout(() => successMsg.classList.add('d-none'), 3000);
            } catch {
                errorMsg.textContent = 'Failed to update status.';
                errorMsg.classList.remove('d-none');
            }
        }

        loadAllOrders();
    </script>
}